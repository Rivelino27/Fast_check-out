rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('superAdmin', false) == true;
    }

    // Quartos: leitura pública, escrita somente admin
    // Hóspede pode fazer check-out quando quarto está ativo com saldo zero
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if resource.data.status == 'active'
                    && resource.data.balance == 0
                    && request.resource.data.status == 'checked-out';
    }

    // Produtos: leitura pública, escrita somente super admin
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    // Pagamentos: leitura pública, criação pública, update somente admin/Functions
    match /payments/{paymentId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Checkouts: leitura pública, criação pública (hóspede), update somente admin
    match /checkouts/{checkoutId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Histórico permanente: admin lê, qualquer um cria, ninguém apaga/edita
    match /checkoutHistory/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // Notificações: somente admin lê/atualiza, criação pública
    match /notifications/{notificationId} {
      allow read, update, delete: if isAdmin();
      allow create: if true;
    }

    // Admins: somente admin lê, escrita somente via console/Functions
    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Meta (upload info, etc.): somente admin
    match /meta/{docId} {
      allow read, write: if isAdmin();
    }

    // Log de edições de reservas: admin lê e cria, ninguém apaga/edita
    match /roomEdits/{editId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
